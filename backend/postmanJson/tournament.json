{
  "info": {
    "name": "Tournament API Test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Dummy collection to test tournament endpoints with Postman."
  },
  "item": [
    {
      "name": "Create Tournament",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{adminToken}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{
            \"name\": \"Test Tournament\",
            \"description\": \"Dummy tournament for testing\",
            \"maxParticipants\": 8,
            \"startDate\": \"{{tomorrow}}\",
            \"endDate\": \"{{dayAfterTomorrow}}\",
            \"registrationDeadline\": \"{{tomorrow}}\",
            \"settings\": {
              \"pointsForWin\": 3,
              \"pointsForDraw\": 1,
              \"pointsForLoss\": 0,
              \"rounds\": \"single\"
            }
          }"
        },
        "url": {"raw": "{{baseUrl}}/tournaments", "host": ["{{baseUrl}}"], "path": ["tournaments"]}
      },
      "response": []
    },
    {
      "name": "Generate Fixtures",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{adminToken}}"}
        ],
        "url": {"raw": "{{baseUrl}}/fixtures/{{tournamentId}}/generate", "host": ["{{baseUrl}}"], "path": ["fixtures", "{{tournamentId}}", "generate"]}
      },
      "response": []
    },
    {
      "name": "Start Tournament",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Authorization", "value": "Bearer {{adminToken}}"}
        ],
        "url": {"raw": "{{baseUrl}}/tournaments/{{tournamentId}}/start", "host": ["{{baseUrl}}"], "path": ["tournaments", "{{tournamentId}}", "start"]}
      },
      "response": []
    },
    {
      "name": "Get League Table",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{adminToken}}"}
        ],
        "url": {"raw": "{{baseUrl}}/fixtures/{{tournamentId}}/league-table", "host": ["{{baseUrl}}"], "path": ["fixtures", "{{tournamentId}}", "league-table"]}
      },
      "response": []
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:3000/api"},
    {"key": "adminToken", "value": "<your_admin_jwt>"},
    {"key": "tournamentId", "value": "<to_be_filled_after_creation>"},
    {"key": "tomorrow", "value": "2026-03-03T00:00:00Z"},
    {"key": "dayAfterTomorrow", "value": "2026-03-04T00:00:00Z"}
  ]
}
